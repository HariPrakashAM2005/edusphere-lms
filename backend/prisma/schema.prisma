generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  firstName    String
  lastName     String
  role         String   @default("STUDENT")
  createdAt    DateTime @default(now())

  enrollments   Enrollment[]
  faceEncodings FaceEncoding[]
  qrSessions    QRCodeSession[]
  assessmentAttempts AssessmentAttempt[]
  certificates       Certificate[]
  chatConversations  ChatConversation[]
  recommendations    UserRecommendation[]
  riskPredictions    RiskPrediction[]

  xpRecords          XPRecord[]
  userLevel          UserLevel?
  userBadges         UserBadge[]
  streak             Streak?
  leaderboardEntries LeaderboardEntry[]
  redemptions        Redemption[]
  questProgress      UserQuestProgress[]
  notifications      Notification[]
  createdCourses     Course[] @relation("FacultyCourses")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String?
  thumbnail   String?
  published   Boolean  @default(false)
  facultyId   String?
  createdAt   DateTime @default(now())

  enrollments Enrollment[]
  qrSessions  QRCodeSession[]
  assessments Assessment[]
  certificates Certificate[]
  chatConversations  ChatConversation[]
  recommendations    UserRecommendation[]
  modules     Module[]
  faculty     User?    @relation("FacultyCourses", fields: [facultyId], references: [id])
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?  @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  content     String?  @db.Text
  videoUrl    String?
  duration    Int      @default(0)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  progress    Float     @default(0)
  isActive    Boolean   @default(true)
  
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  attendanceRecords Attendance[]
  
  @@unique([userId, courseId])
  @@index([userId, isActive])
}

model Attendance {
  id           String   @id @default(cuid())
  enrollmentId String
  date         DateTime
  status       String   // present, absent, late, excused
  method       String   // qr, face, gps, manual
  verifiedBy   String?
  location     String?  // GPS coordinates
  qrCode       String?  // QR code used
  faceMatch    Float?   // confidence score
  createdAt    DateTime @default(now())
  
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  
  @@unique([enrollmentId, date])
  @@index([date, status])
}

model FaceEncoding {
  id         String   @id @default(cuid())
  userId     String
  encoding   Json     // Face embedding array
  createdAt  DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
}

model QRCodeSession {
  id         String   @id @default(cuid())
  courseId   String
  facultyId  String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  
  course  Course @relation(fields: [courseId], references: [id])
  faculty User   @relation(fields: [facultyId], references: [id])
}

model Assessment {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  type        String    // quiz, exam, assignment
  courseId    String
  createdBy   String
  duration    Int?      // in minutes
  passingScore Float    @default(40)
  totalMarks  Float
  isProctored Boolean   @default(false)
  startTime   DateTime?
  endTime     DateTime?
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  course    Course     @relation(fields: [courseId], references: [id])
  questions Question[]
  attempts  AssessmentAttempt[]
  certificates Certificate[]
}

model Question {
  id            String   @id @default(cuid())
  text          String   @db.Text
  type          String   // mcq, truefalse, fillblank, coding, essay
  options       Json?    // for MCQ: array of options
  correctAnswer String?  @db.Text
  explanation   String?  @db.Text
  marks         Float
  difficulty    Int      // 1-5
  assessmentId  String
  order         Int
  
  assessment Assessment @relation(fields: [assessmentId], references: [id])
  answers    Answer[]
}

model AssessmentAttempt {
  id            String    @id @default(cuid())
  userId        String
  assessmentId  String
  startTime     DateTime  @default(now())
  endTime       DateTime?
  score         Float?
  percentage    Float?
  isPassed      Boolean?
  status        String    // in-progress, submitted, timed-out
  proctoringLogs Json?
  
  user       User       @relation(fields: [userId], references: [id])
  assessment Assessment @relation(fields: [assessmentId], references: [id])
  answers    Answer[]
  proctoringLogRecords ProctoringLog[]
}

model Answer {
  id           String    @id @default(cuid())
  attemptId    String
  questionId   String
  answer       String    @db.Text
  isCorrect    Boolean?
  marksAwarded Float?
  feedback     String?   @db.Text
  
  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id])
  question Question          @relation(fields: [questionId], references: [id])
}

model Certificate {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  assessmentId   String?
  serialNumber   String   @unique
  issueDate      DateTime @default(now())
  expiryDate     DateTime?
  pdfUrl         String
  blockchainHash String?
  qrCode         String
  isVerified     Boolean  @default(true)
  score          Float?
  
  user       User       @relation(fields: [userId], references: [id])
  course     Course     @relation(fields: [courseId], references: [id])
  assessment Assessment? @relation(fields: [assessmentId], references: [id])
  
  @@index([serialNumber])
}

model ProctoringLog {
  id         String   @id @default(cuid())
  attemptId  String
  eventType  String   // tab_switch, webcam_snapshot, fullscreen_exit
  timestamp  DateTime @default(now())
  details    Json?
  
  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id])
}

model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  messages  Json     // Array of {role, content, timestamp}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user   User   @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
  
  @@index([userId])
}

model UserRecommendation {
  id             String   @id @default(cuid())
  userId         String
  courseId       String
  score          Float    // Relevance score 0-100
  reason         String   // "Because you completed X", "Similar to Y"
  isViewed       Boolean  @default(false)
  isClicked      Boolean  @default(false)
  createdAt      DateTime @default(now())
  
  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  
  @@index([userId, score])
}

model RiskPrediction {
  id            String   @id @default(cuid())
  userId        String
  riskLevel     String   // low, medium, high
  riskScore     Float    // 0-100
  factors       Json     // {attendance: 45, grades: 60, login_frequency: 30}
  intervention  String?  // Suggested action
  notifiedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id])
  
  @@index([userId, riskLevel])
}

model AIGeneratedContent {
  id          String   @id @default(cuid())
  type        String   // quiz, summary, assignment, flashcard
  sourceId    String   // courseId, lessonId
  content     Json     // Generated content
  createdBy   String
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  @@index([type, sourceId])
}

model XPRecord {
  id        String   @id @default(cuid())
  userId    String
  action    String   // lesson_complete, quiz_pass, attendance_streak, etc.
  xpAmount  Int
  sourceId  String?  // lessonId, assessmentId, etc.
  multiplier Float   @default(1)
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([createdAt])
}

model UserLevel {
  id         String   @id @default(cuid())
  userId     String   @unique
  currentXP  Int      @default(0)
  level      Int      @default(1)
  totalXP    Int      @default(0)
  updatedAt  DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id])
}

model Badge {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String   // learning, attendance, quiz, social, streak, special
  icon          String   // emoji or icon name
  xpRequired    Int?     // if level-based
  action        String?  // specific action to earn
  countRequired Int      @default(1)
  isHidden      Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  
  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])
  
  @@unique([userId, badgeId])
}

model Streak {
  id                 String   @id @default(cuid())
  userId             String   @unique
  currentLoginStreak Int      @default(0)
  longestLoginStreak Int      @default(0)
  lastLoginDate      DateTime?
  currentAssignmentStreak Int @default(0)
  longestAssignmentStreak Int @default(0)
  lastAssignmentDate DateTime?
  currentAttendanceStreak Int @default(0)
  longestAttendanceStreak Int @default(0)
  lastAttendanceDate DateTime?
  updatedAt          DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id])
}

model LeaderboardEntry {
  id         String   @id @default(cuid())
  userId     String
  period     String   // daily, weekly, monthly, all_time
  score      Int      // XP earned in period
  rank       Int?
  updatedAt  DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id])
  
  @@unique([userId, period])
  @@index([period, rank])
}

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String   // certificate, discount, merchandise, perk
  xpCost      Int
  icon        String
  stock       Int?     // null = unlimited
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  
  redemptions Redemption[]
}

model Redemption {
  id         String   @id @default(cuid())
  userId     String
  rewardId   String
  xpSpent    Int
  status     String   // pending, completed, cancelled
  redeemedAt DateTime @default(now())
  
  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])
}

model DailyQuest {
  id          String   @id @default(cuid())
  title       String
  description String
  action      String   // complete_lesson, login, attend_class
  targetCount Int
  xpReward    Int
  activeDate  DateTime @default(now())
  
  userQuestProgress UserQuestProgress[]
  
  @@unique([activeDate, action])
}

model UserQuestProgress {
  id          String   @id @default(cuid())
  userId      String
  questId     String
  progress    Int      @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime?
  
  user  User       @relation(fields: [userId], references: [id])
  quest DailyQuest @relation(fields: [questId], references: [id])
  
  @@unique([userId, questId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // assignment_graded, new_announcement, certificate_issued, attendance_marked, quiz_result_available
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

